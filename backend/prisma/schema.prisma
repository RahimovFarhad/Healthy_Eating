// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  default
  subscriber
  professional
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

enum NutrientType {
  macro
  micro
}

enum Demographic {
  adult
  child_1_3
  child_4_6
  child_7_10
  teen
  older_adult
}

enum Comparator {
  lt      @map("<")
  lte     @map("<=")
  gt      @map(">")
  gte     @map(">=")
  between
  outside
}

enum Severity {
  low
  medium
  high
}

enum RecipeStatus {
  assigned
  viewed
  saved
  cooked
  dismissed
}

enum PlanType {
  auto_suggested
  template
  manual
}

enum FoodSource {
  fatsecret
  user
  system
}

enum GoalSource {
  system_default
  user_defined
  professional_defined
}

enum GoalStatus {
  active
  archived
}

enum ProfessionalClientStatus {
  invited
  active
  disabled
}

enum MessageSender {
  professional
  subscriber
}

model User {
  userId       Int      @id @default(autoincrement()) @map("user_id")
  fullName     String   @map("full_name")
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole
  createdAt    DateTime @default(now()) @map("created_at")

  professionalClientsAsProfessional ProfessionalClient[] @relation("ProfessionalClientProfessional")
  professionalClientsAsSubscriber   ProfessionalClient[] @relation("ProfessionalClientSubscriber")
  diaryEntries                      DiaryEntry[]
  MessagesAsProfessional      Message[]      @relation("MessageProfessional")
  MessagesAsSubscriber        Message[]      @relation("MessageSubscriber")
  nutritionGoalsAsSubscriber        NutritionGoal[]      @relation("NutritionGoalSubscriber")
  nutritionGoalsAsSetter            NutritionGoal[]      @relation("NutritionGoalSetter")
  clientRiskSnapshots               ClientRiskSnapshot[]
  recipeFavorites                   RecipeFavorite[]
  recipeAssignmentsAsProfessional   RecipeAssignment[]   @relation("RecipeAssignmentProfessional")
  recipeAssignmentsAsSubscriber     RecipeAssignment[]   @relation("RecipeAssignmentSubscriber")
  recipeReviews                     RecipeReview[]
  plans                             Plan[]
  createdFoodItems                  FoodItem[]           @relation("FoodItemCreatedByUser")

  @@map("user")
}

model ProfessionalClient {
  id             Int                      @id @default(autoincrement())
  professionalId Int                      @map("professional_id")
  subscriberId   Int                      @map("subscriber_id")
  status         ProfessionalClientStatus @default(invited)
  assignedAt     DateTime                 @default(now()) @map("assigned_at")

  professional User @relation("ProfessionalClientProfessional", fields: [professionalId], references: [userId], onDelete: Cascade)
  subscriber   User @relation("ProfessionalClientSubscriber", fields: [subscriberId], references: [userId], onDelete: Cascade)

  @@unique([professionalId, subscriberId])
  @@map("professional_client")
}

// ---- Food diary ----
model FoodItem {
  foodItemId      Int        @id @default(autoincrement()) @map("food_item_id")
  name            String
  brand           String?
  source          FoodSource
  externalId      String?    @map("external_id")
  createdByUserId Int?       @map("created_by_user_id")
  createdAt       DateTime   @default(now()) @map("created_at")

  createdByUser User?         @relation("FoodItemCreatedByUser", fields: [createdByUserId], references: [userId], onDelete: SetNull)
  portions      FoodPortion[]

  @@unique([source, externalId])
  @@map("food_item")
}

model Nutrient {
  nutrientId Int          @id @default(autoincrement()) @map("nutrient_id")
  code       String       @unique
  name       String
  unit       String
  type       NutrientType

  foodPortionNutrients FoodPortionNutrient[]
  nutritionGoals       NutritionGoal[]
  guidelines           Guideline[]
  riskRules            RiskRule[]

  @@map("nutrient")
}

model FoodPortion {
  portionId   Int      @id @default(autoincrement()) @map("portion_id")
  foodItemId  Int      @map("food_item_id")
  description String
  weightG     Decimal? @map("weight_g") @db.Decimal(10, 2)

  foodItem         FoodItem              @relation(fields: [foodItemId], references: [foodItemId], onDelete: Cascade)
  portionNutrients FoodPortionNutrient[]
  diaryEntryItems  DiaryEntryItem[]

  @@map("food_portion")
}

model FoodPortionNutrient {
  id         Int     @id @default(autoincrement())
  portionId  Int     @map("portion_id")
  nutrientId Int     @map("nutrient_id")
  amount     Decimal @db.Decimal(12, 4)

  portion  FoodPortion @relation(fields: [portionId], references: [portionId], onDelete: Cascade)
  nutrient Nutrient    @relation(fields: [nutrientId], references: [nutrientId], onDelete: Cascade)

  @@unique([portionId, nutrientId])
  @@map("food_portion_nutrient")
}

model DiaryEntry {
  diaryEntryId Int      @id @default(autoincrement()) @map("diary_entry_id")
  subscriberId Int      @map("subscriber_id")
  consumedAt   DateTime @map("consumed_at")
  mealType     MealType @map("meal_type")
  notes        String?

  subscriber User             @relation(fields: [subscriberId], references: [userId], onDelete: Cascade)
  items      DiaryEntryItem[]

  @@map("diary_entry")
}

model DiaryEntryItem {
  id           Int     @id @default(autoincrement())
  diaryEntryId Int     @map("diary_entry_id")
  portionId    Int     @map("portion_id")
  quantity     Decimal @map("quantity") @db.Decimal(10, 3)

  diaryEntry DiaryEntry  @relation(fields: [diaryEntryId], references: [diaryEntryId], onDelete: Cascade)
  portion    FoodPortion @relation(fields: [portionId], references: [portionId], onDelete: Cascade)

  @@map("diary_entry_item")
}

model Message {
  id       Int      @id @default(autoincrement()) @map("id")
  professionalId Int      @map("professional_id")
  subscriberId   Int      @map("subscriber_id")
  message        String   @db.Text
  sentBy         MessageSender @map("sent_by")
  createdAt      DateTime @default(now()) @map("created_at")

  professional User @relation("MessageProfessional", fields: [professionalId], references: [userId], onDelete: Cascade)
  subscriber   User @relation("MessageSubscriber", fields: [subscriberId], references: [userId], onDelete: Cascade)

  @@map("message")
}

model NutritionGoal {
  goalId              Int         @id @default(autoincrement()) @map("goal_id")
  subscriberId        Int         @map("subscriber_id")
  nutrientId          Int?        @map("nutrient_id")
  source              GoalSource  @default(system_default)
  status              GoalStatus  @default(active)
  targetMin           Decimal?    @map("target_min") @db.Decimal(12, 4)
  targetMax           Decimal?    @map("target_max") @db.Decimal(12, 4)

  setByProfessionalId Int?        @map("set_by_professional_id")
  startDate           DateTime    @map("start_date") @db.Date
  endDate             DateTime?   @map("end_date") @db.Date
  notes               String?
  createdAt          DateTime    @default(now()) @map("created_at") 

  subscriber        User          @relation("NutritionGoalSubscriber", fields: [subscriberId], references: [userId], onDelete: Cascade)
  setByProfessional User?         @relation("NutritionGoalSetter", fields: [setByProfessionalId], references: [userId], onDelete: SetNull)
  nutrient          Nutrient?     @relation(fields: [nutrientId], references: [nutrientId], onDelete: Cascade)

  @@map("nutrition_goal")
}

model Guideline {
  guidelineId Int         @id @default(autoincrement()) @map("guideline_id")
  nutrientId  Int         @map("nutrient_id")
  demographic Demographic
  source      String

  minValue    Decimal?    @map("min_value") @db.Decimal(12, 4)
  maxValue    Decimal?    @map("max_value") @db.Decimal(12, 4)

  nutrient Nutrient @relation(fields: [nutrientId], references: [nutrientId], onDelete: Cascade)

  @@map("guideline")
}

model RiskRule {
  ruleId       Int        @id @default(autoincrement()) @map("rule_id")
  name         String
  description  String?
  nutrientId   Int?       @map("nutrient_id")
  comparator   Comparator
  thresholdMin Decimal?   @map("threshold_min") @db.Decimal(12, 4)
  thresholdMax Decimal?   @map("threshold_max") @db.Decimal(12, 4)
  windowDays   Int        @map("window_days")
  severity     Severity
  isActive     Boolean    @map("is_active")

  nutrient  Nutrient?            @relation(fields: [nutrientId], references: [nutrientId], onDelete: SetNull)
  snapshots ClientRiskSnapshot[]

  @@map("risk_rule")
}

model ClientRiskSnapshot {
  snapshotId   Int      @id @default(autoincrement()) @map("snapshot_id")
  subscriberId Int      @map("subscriber_id")
  ruleId       Int      @map("rule_id")
  riskLevel    Severity @map("risk_level")
  score        Decimal? @db.Decimal(12, 4)
  reason       String?
  computedAt   DateTime @default(now()) @map("computed_at")

  subscriber User     @relation(fields: [subscriberId], references: [userId], onDelete: Cascade)
  rule       RiskRule @relation(fields: [ruleId], references: [ruleId], onDelete: Cascade)

  @@map("client_risk_snapshot")
}

// ==================== RECIPES ====================

model Recipe {
  recipeId     Int    @id @default(autoincrement()) @map("recipe_id")
  title        String
  instructions String @db.Text

  recipeIngredients RecipeIngredient[]
  favorites         RecipeFavorite[]
  assignments       RecipeAssignment[]
  reviews           RecipeReview[]
  planItems         PlanItem[]

  @@map("recipe")
}

model Ingredient {
  ingredientId Int    @id @default(autoincrement()) @map("ingredient_id")
  name         String @unique

  recipeIngredients RecipeIngredient[]

  @@map("ingredient")
}

model RecipeIngredient {
  id           Int     @id @default(autoincrement())
  recipeId     Int     @map("recipe_id")
  ingredientId Int     @map("ingredient_id")
  quantity     String?

  recipe     Recipe     @relation(fields: [recipeId], references: [recipeId], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [ingredientId], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
  @@map("recipe_ingredient")
}

model RecipeFavorite {
  id           Int      @id @default(autoincrement())
  subscriberId Int      @map("subscriber_id")
  recipeId     Int      @map("recipe_id")
  createdAt    DateTime @default(now()) @map("created_at")

  subscriber User   @relation(fields: [subscriberId], references: [userId], onDelete: Cascade)
  recipe     Recipe @relation(fields: [recipeId], references: [recipeId], onDelete: Cascade)

  @@unique([subscriberId, recipeId])
  @@map("recipe_favorite")
}

model RecipeAssignment {
  assignmentId   Int          @id @default(autoincrement()) @map("assignment_id")
  professionalId Int          @map("professional_id")
  subscriberId   Int          @map("subscriber_id")
  recipeId       Int          @map("recipe_id")
  note           String?
  status         RecipeStatus
  assignedAt     DateTime     @default(now()) @map("assigned_at")

  professional User   @relation("RecipeAssignmentProfessional", fields: [professionalId], references: [userId], onDelete: Cascade)
  subscriber   User   @relation("RecipeAssignmentSubscriber", fields: [subscriberId], references: [userId], onDelete: Cascade)
  recipe       Recipe @relation(fields: [recipeId], references: [recipeId], onDelete: Cascade)

  @@map("recipe_assignment")
}

model RecipeReview {
  reviewId     Int      @id @default(autoincrement()) @map("review_id")
  subscriberId Int      @map("subscriber_id")
  recipeId     Int      @map("recipe_id")
  rating       Int
  comment      String?   @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  subscriber User   @relation(fields: [subscriberId], references: [userId], onDelete: Cascade)
  recipe     Recipe @relation(fields: [recipeId], references: [recipeId], onDelete: Cascade)

  @@unique([subscriberId, reviewId])
  @@map("recipe_review")
}

// ==================== MEAL PLANNING ====================

model Plan {
  planId       Int       @id @default(autoincrement()) @map("plan_id")
  subscriberId Int       @map("subscriber_id")
  planType     PlanType  @map("plan_type")
  startDate    DateTime  @map("start_date") @db.Date
  endDate      DateTime? @map("end_date") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at")

  subscriber User       @relation(fields: [subscriberId], references: [userId], onDelete: Cascade)
  planItems  PlanItem[]

  @@map("plan")
}

model PlanItem {
  planItemId  Int      @id @default(autoincrement()) @map("plan_item_id")
  planId      Int      @map("plan_id")
  plannedDate DateTime @map("planned_date") @db.Date
  mealType    MealType @map("meal_type")
  recipeId    Int      @map("recipe_id")
  servings    Int?

  plan   Plan   @relation(fields: [planId], references: [planId], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [recipeId], onDelete: Cascade)

  @@map("plan_item")
}
