@startuml
skinparam classAttributeIconSize 0
hide empty members

package "auth" {
class AuthController <<controller>> {
  +login()
  +register()
  +verifyRegistration()
  +resendVerificationCode()
  +refreshToken()
  +logoutController()
}
class AuthService <<service>> {
  +authenticateUser()
  +registerUser()
  +verifyRegistrationCode()
  +resendRegistrationCode()
  +generateRefreshToken()
  +refreshAccessToken()
  +revokeRefreshToken()
  +normalizeEmail()
  +normalizeUsername()
}
class AuthRoutes <<routes>> {
  +POST /login -> login()
  +POST /register -> register()
  +POST /register/verify -> verifyRegistration()
  +POST /register/resend -> resendVerificationCode()
  +GET /refresh -> refreshToken()
  +POST /logout -> logoutController()
}
}

