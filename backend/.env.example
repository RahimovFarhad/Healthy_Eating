# PostgreSQL connection string
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5432/healthy_eating"

# JWT signing secret — use a strong random value in production
# Generate one with: openssl rand -hex 32
JWT_SECRET="replace-with-a-random-secret"

# Port the backend server listens on
PORT=3000

# FatSecret API credentials
# Register at https://platform.fatsecret.com to get these
FATSECRET_CLIENT_ID="your-fatsecret-client-id"
FATSECRET_CLIENT_SECRET="your-fatsecret-client-secret"

# Gmail / Google OAuth credentials for sending verification emails
# Set up a Google Cloud project and enable the Gmail API to get these
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REFRESH_TOKEN="your-google-refresh-token"
GMAIL_USER="your-gmail-address@gmail.com"
